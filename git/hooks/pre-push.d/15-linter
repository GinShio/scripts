#!/bin/sh
. "$HOOKS_DIR/core/lib.sh"

# The heavy, compile-based lint tier. Static per-file linters run at commit time
# (pre-commit.d/60-linter); clippy builds the whole crate, so it belongs here —
# once per push, over just the crates whose Rust sources are going out — rather
# than on every commit. On by default when cargo is installed; a missing cargo
# is a silent pass.
cfg_bool wits.hooks.pre-push.linter-rust-disable false && exit 0
command -v cargo >/dev/null 2>&1 || exit 0
null_sha

# clippy is crate-oriented: walk up from a staged .rs file to the nearest
# Cargo.toml. Failure means the file belongs to no crate clippy can see.
find_crate_manifest() {
    _d=$(dirname -- "$1")
    while :; do
        [ -f "$_d/Cargo.toml" ] && { printf '%s\n' "$_d/Cargo.toml"; return 0; }
        case "$_d" in
            .|/) return 1 ;;
        esac
        _d=$(dirname -- "$_d")
    done
}

# stdin (one line per ref): <local_ref> <local_sha> <remote_ref> <remote_sha>.
# Gather the files changing in the commits being pushed. The range only selects
# *which crates* to lint — clippy checks the working tree regardless — so a
# slightly wide range just lints an extra crate, never the wrong content.
changed=""
while read -r local_ref local_sha remote_ref remote_sha; do
    [ "$local_sha" = "$NULL_SHA" ] && continue   # branch deletion: nothing to lint

    if [ "$remote_sha" = "$NULL_SHA" ]; then
        # New branch on the remote: diff from its merge-base with the main branch.
        base=$(git merge-base "$local_sha" "$(get_main_branch)" 2>/dev/null) || continue
        [ -n "$base" ] || continue
        range="$base..$local_sha"
    else
        range="$remote_sha..$local_sha"
    fi

    files=$(git diff --name-only --diff-filter=ACM "$range" 2>/dev/null)
    [ -n "$files" ] && changed="${changed:+$changed
}$files"
done

[ -n "$changed" ] || exit 0

oldifs=$IFS
IFS='
'
set -f

# Map the changed .rs files onto the distinct crates that own them (dedup), so a
# subdir crate is linted and a file in no crate is skipped rather than aborting.
manifests="" ; stray=0
for f in $changed; do
    case "$f" in *.rs) ;; *) continue ;; esac
    if m=$(find_crate_manifest "$f"); then
        case "
$manifests
" in
            *"
$m
"*) ;;                        # crate already queued
            *) manifests="${manifests:+$manifests
}$m" ;;
        esac
    else
        stray=1
    fi
done

[ "$stray" = 1 ] &&
    log_warn "some changed .rs files belong to no Cargo.toml; skipping clippy for them"

rc=0
for m in $manifests; do
    log_info "clippy: $m"
    cargo clippy --manifest-path "$m" -- -D warnings || rc=1
done

IFS=$oldifs
set +f

[ "$rc" -eq 0 ] || log_error "clippy failed; fix the warnings above or push with --no-verify"
exit $rc
