#!/bin/sh
. "$HOOKS_DIR/core/lib.sh"

# Block a commit that stages a secret. Active whenever a scanner is installed
# (gitleaks preferred), a silent pass otherwise — installing the tool is how you
# turn it on.
if command -v gitleaks >/dev/null 2>&1; then
    if ! gitleaks protect --staged --redact; then
        log_error "gitleaks flagged a potential secret; commit blocked (bypass a false positive with --no-verify)"
        exit 1
    fi
elif command -v git-secrets >/dev/null 2>&1; then
    if ! git secrets --scan; then
        log_error "git-secrets flagged a potential secret; commit blocked"
        exit 1
    fi
fi

exit 0
