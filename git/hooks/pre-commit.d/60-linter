#!/bin/sh
. "$HOOKS_DIR/core/lib.sh"

# Fast, file-oriented static analysis of the *staged* content — the version
# actually being committed, so a partially-staged file is linted exactly as it
# lands, not with the unstaged edits still in the working tree. Tools that read
# stdin (ruff, flake8) are fed the staged blob directly with the real path so
# their config resolution and diagnostics stay accurate; those that only take a
# path (zig ast-check) run against a materialized copy.
#
# The compile-based Rust check (clippy) is deliberately *not* here: it builds the
# whole crate and is far too heavy for every commit. It runs at push time
# instead (pre-push.d/15-linter). Each language is on by default and turned off
# on its own via a `-disable` switch; a missing tool warns rather than fails.
PYTHON=$(cfg_bool wits.hooks.pre-commit.linter-python-disable false && echo 0 || echo 1)
ZIG=$(cfg_bool wits.hooks.pre-commit.linter-zig-disable false && echo 0 || echo 1)

files=$(staged_files)
[ -n "$files" ] || exit 0

rc=0
oldifs=$IFS
IFS='
'
set -f

# Bucket staged paths by language (newline-separated so paths may contain
# spaces; the unquoted expansions below rely on IFS still being a newline).
py="" ; zig=""
for file in $files; do
    is_staged_text "$file" || continue   # never feed a binary blob to a linter
    is_encrypted "$file" && continue      # its staged blob is ciphertext, not source
    case "$file" in
        *.py|*.pyi)  py="${py:+$py
}$file" ;;
        *.zig|*.zon) zig="${zig:+$zig
}$file" ;;
    esac
done

if [ "$PYTHON" = 1 ] && [ -n "$py" ]; then
    if command -v ruff >/dev/null 2>&1; then
        for f in $py; do
            staged_blob "$f" | ruff check --stdin-filename "$f" - || rc=1
        done
    elif command -v flake8 >/dev/null 2>&1; then
        for f in $py; do
            staged_blob "$f" | flake8 --stdin-display-name "$f" - || rc=1
        done
    else
        log_warn "python lint enabled but neither ruff nor flake8 is installed"
    fi
fi

if [ "$ZIG" = 1 ] && [ -n "$zig" ]; then
    if command -v zig >/dev/null 2>&1; then
        for f in $zig; do
            # zig ast-check takes a path, not stdin; materialize the staged blob
            # under its own basename so any diagnostic still names the file.
            d=$(mktemp -d) || { rc=1; continue; }
            t="$d/${f##*/}"
            if staged_blob "$f" > "$t"; then
                zig ast-check "$t" || rc=1
            fi
            rm -rf "$d"
        done
    else
        log_warn "zig lint enabled but zig is not installed"
    fi
fi

IFS=$oldifs
set +f

[ "$rc" -eq 0 ] || log_error "lint failed; fix the issues above or commit with --no-verify"
exit $rc
