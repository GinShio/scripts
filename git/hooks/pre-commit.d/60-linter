#!/bin/sh
. "$HOOKS_DIR/core/lib.sh"

# Fast static analysis of the staged languages, run on the working-tree copies
# (linters need real files). Most tools are file-oriented and take paths; clippy
# is crate-oriented, so it is dispatched per owning crate (see below). Each
# language runs by default and is turned off on its own via a `-disable` switch;
# a missing tool warns rather than fails.
PYTHON=$(cfg_bool wits.hooks.pre-commit.linter-python-disable false && echo 0 || echo 1)
ZIG=$(cfg_bool wits.hooks.pre-commit.linter-zig-disable false && echo 0 || echo 1)
RUST=$(cfg_bool wits.hooks.pre-commit.linter-rust-disable false && echo 0 || echo 1)

# clippy is crate-oriented, so — unlike the file-oriented linters below — it needs
# a manifest. Walk up from a staged .rs file to the nearest Cargo.toml; failure
# means the file belongs to no crate and clippy simply cannot see it.
find_crate_manifest() {
    _d=$(dirname -- "$1")
    while :; do
        [ -f "$_d/Cargo.toml" ] && { printf '%s\n' "$_d/Cargo.toml"; return 0; }
        case "$_d" in
            .|/) return 1 ;;
        esac
        _d=$(dirname -- "$_d")
    done
}

files=$(staged_files)
[ -n "$files" ] || exit 0

rc=0
oldifs=$IFS
IFS='
'
set -f

# Bucket staged paths by language (newline-separated so paths may contain
# spaces; the unquoted expansions below rely on IFS still being a newline).
py="" ; zig="" ; rs=""
for file in $files; do
    is_staged_text "$file" || continue   # never feed a binary blob to a linter
    case "$file" in
        *.py|*.pyi)  py="${py:+$py
}$file" ;;
        *.zig|*.zon) zig="${zig:+$zig
}$file" ;;
        *.rs)        rs="${rs:+$rs
}$file" ;;
    esac
done

if [ "$PYTHON" = 1 ] && [ -n "$py" ]; then
    if command -v ruff >/dev/null 2>&1; then
        ruff check -- $py || rc=1
    elif command -v flake8 >/dev/null 2>&1; then
        flake8 -- $py || rc=1
    else
        log_warn "python lint enabled but neither ruff nor flake8 is installed"
    fi
fi

if [ "$ZIG" = 1 ] && [ -n "$zig" ]; then
    if command -v zig >/dev/null 2>&1; then
        for f in $zig; do zig ast-check "$f" || rc=1; done
    else
        log_warn "zig lint enabled but zig is not installed"
    fi
fi

if [ "$RUST" = 1 ] && [ -n "$rs" ]; then
    if command -v cargo >/dev/null 2>&1; then
        # Map the staged .rs files onto the distinct crates that own them, so a
        # subdir crate is linted and a repo with no root manifest doesn't abort.
        manifests="" ; stray=0
        for f in $rs; do
            if m=$(find_crate_manifest "$f"); then
                case "
$manifests
" in
                    *"
$m
"*) ;;                       # crate already queued
                    *) manifests="${manifests:+$manifests
}$m" ;;
                esac
            else
                stray=1
            fi
        done
        [ "$stray" = 1 ] &&
            log_warn "some staged .rs files belong to no Cargo.toml; skipping clippy for them"
        for m in $manifests; do
            cargo clippy --manifest-path "$m" -- -D warnings || rc=1
        done
    else
        log_warn "rust lint enabled but cargo is not installed"
    fi
fi

IFS=$oldifs
set +f

[ "$rc" -eq 0 ] || log_error "lint failed; fix the issues above or commit with --no-verify"
exit $rc
